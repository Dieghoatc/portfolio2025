---
import type { ImageMetadata } from "astro";

interface Tag {
  icon?: ImageMetadata;
  label: string;
}

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
  link: string;
  linkLabel?: string;
  tags?: Tag[];
}

const {
  title,
  description,
  image,
  imageAlt = title,
  link,
  linkLabel = "Live",
  tags = [],
} = Astro.props;

const domain = link.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${title} — opens in a new tab`}
  class="project-card group block w-full sm:w-[320px]"
>
  {
    image ? (
      <div class="w-full overflow-hidden rounded-2xl aspect-video shadow-md shadow-amber-400/20">
        <img
          src={image.src}
          class="object-cover w-full h-full transition-transform duration-300 group-hover:scale-105"
          alt={imageAlt}
        />
      </div>
    ) : (
      <div class="w-full overflow-hidden rounded-2xl aspect-video shadow-md shadow-amber-400/20 placeholder flex items-center justify-center">
        <span class="font-mono text-amber-200/80 text-[13px]">{domain}</span>
      </div>
    )
  }
  <div class="mx-2 mt-3">
    <h2 class="font-bold text-[18px] group-hover:text-amber-300 transition-colors">
      {title}
    </h2>
    <p class="text-gray-400">{description}</p>
    {
      tags.length > 0 && (
        <div class="mt-2 flex gap-2 flex-wrap">
          {tags.map((tag) => (
            <div class="flex gap-1 justify-center items-center">
              {tag.icon && <img class="logo" src={tag.icon.src} alt={`${tag.label} logo`} />}
              <span class="text-[12px]">{tag.label}</span>
            </div>
          ))}
        </div>
      )
    }
    <div class="flex gap-2 mt-5">
      <div>
        <span class="text-amber-300">{linkLabel}</span>
      </div>
      <div>
        <svg
          width="15"
          height="15"
          viewBox="0 0 15 15"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 13C12.5523 13 13 12.5523 13 12V3C13 2.44771 12.5523 2 12 2H3C2.44771 2 2 2.44771 2 3V6.5C2 6.77614 2.22386 7 2.5 7C2.77614 7 3 6.77614 3 6.5V3H12V12H8.5C8.22386 12 8 12.2239 8 12.5C8 12.7761 8.22386 13 8.5 13H12ZM9 6.5C9 6.5001 9 6.50021 9 6.50031V6.50035V9.5C9 9.77614 8.77614 10 8.5 10C8.22386 10 8 9.77614 8 9.5V7.70711L2.85355 12.8536C2.65829 13.0488 2.34171 13.0488 2.14645 12.8536C1.95118 12.6583 1.95118 12.3417 2.14645 12.1464L7.29289 7H5.5C5.22386 7 5 6.77614 5 6.5C5 6.22386 5.22386 6 5.5 6H8.5C8.56779 6 8.63244 6.01349 8.69139 6.03794C8.74949 6.06198 8.80398 6.09744 8.85143 6.14433C8.94251 6.23434 8.9992 6.35909 8.99999 6.49708L8.99999 6.49738"
            fill="currentColor"></path></svg
        >
      </div>
    </div>
  </div>
</a>

<style>
  .logo {
    width: 15px;
    height: 15px;
  }
  .placeholder {
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2410 100%);
    border: 1px solid rgba(209, 176, 0, 0.15);
  }
  .project-card:focus-visible {
    outline: 2px solid #d1b000;
    outline-offset: 4px;
    border-radius: 1rem;
  }
</style>
